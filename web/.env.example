# Stripe — billing
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx           # $0.99/mo recurring price (create in Stripe Dashboard)

# Resend — transactional email
RESEND_API_KEY=re_xxx
FROM_EMAIL=Yogurt Watch <updates@your-domain.app>

# Telegram bot — same token used by yogurt_monitor.py
TELEGRAM_BOT_TOKEN=xxx:yyy

# Vercel cron protection (Vercel sets Authorization: Bearer ${CRON_SECRET} on cron requests)
CRON_SECRET=long-random-string

# Vercel KV — auto-set by `vercel link` after enabling the KV addon
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
